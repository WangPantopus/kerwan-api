# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Railway, Supabase, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/kerwan_dev

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — copy from your Stripe Dashboard > Products
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_YEARLY=price_...
STRIPE_PRICE_SOLO_LIFETIME=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_PRO_LIFETIME=price_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Kerwan <noreply@kerwan.app>

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://kerwan.app
APP_LATEST_VERSION=1.0.0
APP_DOWNLOAD_BASE_URL=https://releases.kerwan.app
APP_RELEASE_NOTES_URL=https://kerwan.app/changelog

# Checkout redirect URLs
CHECKOUT_SUCCESS_URL=https://kerwan.app/welcome?session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=https://kerwan.app/pricing

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" for all
CORS_ORIGIN=*

# ─── Optional ─────────────────────────────────────────────────────────────────
# ADMIN_API_KEY=a-very-long-random-string-at-least-32-chars
